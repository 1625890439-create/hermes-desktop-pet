# ========================================
# Hermes Desktop Pet 环境变量配置示例
# 复制此文件为 .env 并修改即可
# ========================================

# --- Hermes API 连接 ---
# API Server 地址（默认连接本地 8643 端口）
# HERMES_API_ENDPOINT=http://localhost:8643/v1/chat/completions
# API 密钥（为空则不需要验证）
# HERMES_DESKTOP_PET_KEY=
# 模型名称
# HERMES_MODEL_NAME=desktop-pet

# --- 窗口大小 ---
# PET_WIDTH=150
# PET_HEIGHT=200
# CHAT_WIDTH=360
# CHAT_HEIGHT=480

# --- 字体 ---
# FONT_FAMILY=Microsoft YaHei, Segoe UI, Arial
# FONT_SIZE_CHAT=13

# --- 语音 ---
# TTS_PROVIDER=edge-tts
# TTS_VOICE=zh-CN-XiaoxiaoNeural
# STT_PROVIDER=google

# --- API 超时 ---
# API_TIMEOUT=120.0
# MAX_HISTORY_LENGTH=50
